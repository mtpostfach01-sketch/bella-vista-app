generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Standort ─────────────────────────────────────────────────
model Standort {
  id      Int    @id @default(autoincrement())
  name    String @unique
  adresse String

  bereiche              Bereich[]
  tische                Tisch[]
  reservierungen        Reservierung[]
  speisekarte           Speisekarte?
  bestellungen          Bestellung[]
  mitarbeiter           Mitarbeiter[]
  warteliste            Warteliste[]
  schichten             Schicht[]
  trinkgeldverteilungen Trinkgeldverteilung[]
  gruppenmenues         Gruppenmenue[]
  cateringAuftraege     CateringAuftrag[]
}

// ─── Gast (standortübergreifend, ADR-003) ─────────────────────
model Gast {
  id             Int     @id @default(autoincrement())
  vorname        String
  nachname       String
  telefon        String  @unique
  email          String?
  notiz          String?
  lieblingstisch String? // CRM: bevorzugter Tisch (Freitext, z. B. "Tisch 4 Terrasse")
  bella_card     Boolean @default(false)
  besuchsanzahl  Int     @default(0)

  reservierungen Reservierung[]
  rechnungen     Rechnung[]
  warteliste     Warteliste[]
}

// ─── Bereich ──────────────────────────────────────────────────
model Bereich {
  id          Int      @id @default(autoincrement())
  name        String
  standort_id Int
  standort    Standort @relation(fields: [standort_id], references: [id])

  tische Tisch[]
}

// ─── Tisch ────────────────────────────────────────────────────
model Tisch {
  id          Int      @id @default(autoincrement())
  nummer      Int
  kapazitaet  Int
  status      String   @default("FREI") // FREI | BESETZT | RESERVIERT | GESPERRT
  bereich_id  Int
  standort_id Int
  bereich     Bereich  @relation(fields: [bereich_id], references: [id])
  standort    Standort @relation(fields: [standort_id], references: [id])

  reservierungen Reservierung[]
  bestellungen   Bestellung[]

  @@unique([nummer, standort_id])
}

// ─── Reservierung ─────────────────────────────────────────────
model Reservierung {
  id                Int           @id @default(autoincrement())
  datum_uhrzeit     DateTime
  personenanzahl    Int
  status            String        @default("BESTAETIGT") // BESTAETIGT | NO_SHOW | STORNIERT | ERSCHIENEN
  notiz             String?
  erstellt_am       DateTime      @default(now())
  gast_id           Int
  tisch_id          Int?
  standort_id       Int
  gruppenmenue_id   Int? // BR #6: ab Schwellwert vorgeschlagen
  anzahlung_betrag  Float? // BR #23: optional, fallweise
  anzahlung_bezahlt Boolean       @default(false)
  gast              Gast          @relation(fields: [gast_id], references: [id])
  tisch             Tisch?        @relation(fields: [tisch_id], references: [id])
  standort          Standort      @relation(fields: [standort_id], references: [id])
  gruppenmenue      Gruppenmenue? @relation(fields: [gruppenmenue_id], references: [id])

  erinnerung Erinnerung?
}

// ─── Mitarbeiter ──────────────────────────────────────────────
model Mitarbeiter {
  id          Int       @id @default(autoincrement())
  vorname     String
  nachname    String
  email       String    @unique
  rolle       String // CHEF | MANAGER | BEDIENUNG
  standort_id Int? // null = Chef (alle Standorte)
  standort    Standort? @relation(fields: [standort_id], references: [id])

  bestellungen          Bestellung[]
  schichten             Schicht[]
  trinkgeldverteilungen Trinkgeldverteilung[]
}

// ─── Speisekarte ──────────────────────────────────────────────
model Speisekarte {
  id          Int      @id @default(autoincrement())
  standort_id Int      @unique
  standort    Standort @relation(fields: [standort_id], references: [id])

  kategorien Kategorie[]
}

model Kategorie {
  id             Int         @id @default(autoincrement())
  name           String
  speisekarte_id Int
  speisekarte    Speisekarte @relation(fields: [speisekarte_id], references: [id])

  gerichte Gericht[]
}

// ─── Allergen ─────────────────────────────────────────────────
model Allergen {
  id      Int    @id @default(autoincrement())
  name    String
  kuerzel String @unique

  gerichte GerichtAllergen[]
}

// ─── Gericht ──────────────────────────────────────────────────
model Gericht {
  id               Int       @id @default(autoincrement())
  name             String
  beschreibung     String?
  preis            Float
  verfuegbar       Boolean   @default(true)
  ist_grillgericht Boolean   @default(false) // BR #8: nur Kreuzberg
  foto_url         String? // BV-109
  kategorie_id     Int
  kategorie        Kategorie @relation(fields: [kategorie_id], references: [id])

  allergene          GerichtAllergen[]
  bestellpositionen  Bestellposition[]
  tagesgerichte      Tagesgericht[]
  cateringPositionen CateringPosition[]
}

model GerichtAllergen {
  gericht_id  Int
  allergen_id Int
  gericht     Gericht  @relation(fields: [gericht_id], references: [id])
  allergen    Allergen @relation(fields: [allergen_id], references: [id])

  @@id([gericht_id, allergen_id])
}

model Tagesgericht {
  id          Int      @id @default(autoincrement())
  datum       DateTime
  standort_id Int
  gericht_id  Int
  gericht     Gericht  @relation(fields: [gericht_id], references: [id])

  @@unique([gericht_id, datum, standort_id])
}

// ─── Bestellung ───────────────────────────────────────────────
model Bestellung {
  id                  Int              @id @default(autoincrement())
  status              String           @default("OFFEN") // OFFEN | IN_ZUBEREITUNG | SERVIERT | BEZAHLT | STORNIERT
  bestellart          String           @default("TISCH") // TISCH | ABHOLUNG | CATERING (BV-107, W9)
  erstellt_am         DateTime         @default(now())
  tisch_id            Int? // optional: null bei Abholung/Catering (BV-107, W9)
  standort_id         Int
  mitarbeiter_id      Int
  catering_auftrag_id Int? // W9: gesetzt, wenn aus Catering-Auftrag erzeugt
  tisch               Tisch?           @relation(fields: [tisch_id], references: [id])
  standort            Standort         @relation(fields: [standort_id], references: [id])
  mitarbeiter         Mitarbeiter      @relation(fields: [mitarbeiter_id], references: [id])
  cateringAuftrag     CateringAuftrag? @relation(fields: [catering_auftrag_id], references: [id])

  positionen     Bestellposition[]
  kuechenauftrag Kuechenauftrag?
  rechnungen     Rechnung[]
}

model Bestellposition {
  id            Int        @id @default(autoincrement())
  menge         Int
  einzelpreis   Float // Preis zum Zeitpunkt der Bestellung (historisch korrekt)
  notiz         String?
  status        String     @default("OFFEN") // OFFEN | IN_ZUBEREITUNG | FERTIG
  bestellung_id Int
  gericht_id    Int
  bestellung    Bestellung @relation(fields: [bestellung_id], references: [id])
  gericht       Gericht    @relation(fields: [gericht_id], references: [id])
}

// ─── Küchenauftrag ────────────────────────────────────────────
model Kuechenauftrag {
  id            Int        @id @default(autoincrement())
  status        String     @default("OFFEN") // OFFEN | IN_ARBEIT | FERTIG
  erstellt_am   DateTime   @default(now())
  bestellung_id Int        @unique
  bestellung    Bestellung @relation(fields: [bestellung_id], references: [id])
}

// ─── Rechnung + Zahlung ───────────────────────────────────────
model Rechnung {
  id                          Int        @id @default(autoincrement())
  bella_card_rabatt           Boolean    @default(false)
  gesamt_betrag               Float
  trinkgeld                   Float      @default(0)
  erstellt_am                 DateTime   @default(now())
  bestellung_id               Int
  gast_id                     Int?
  tse_uebermittelt            Boolean    @default(false) // BV-108: Stub, siehe ADR-007
  tse_uebermittlungszeitpunkt DateTime?
  bestellung                  Bestellung @relation(fields: [bestellung_id], references: [id])
  gast                        Gast?      @relation(fields: [gast_id], references: [id])

  zahlungen Zahlung[]
}

model Zahlung {
  id          Int      @id @default(autoincrement())
  betrag      Float
  zahlungsart String // BAR | KARTE
  rechnung_id Int
  rechnung    Rechnung @relation(fields: [rechnung_id], references: [id])
}

// ─── Warteliste (BV-102) ──────────────────────────────────────
model Warteliste {
  id                       Int      @id @default(autoincrement())
  gewuenschte_personenzahl Int
  notiz                    String?
  erstellt_am              DateTime @default(now())
  gast_id                  Int
  standort_id              Int
  gast                     Gast     @relation(fields: [gast_id], references: [id])
  standort                 Standort @relation(fields: [standort_id], references: [id])
}

// ─── Schicht (BV-103) ─────────────────────────────────────────
model Schicht {
  id             Int         @id @default(autoincrement())
  datum          DateTime
  von            String // "18:00"
  bis            String // "23:00"
  einspring_flag Boolean     @default(false) // Mitarbeiter springt an anderem Standort ein
  mitarbeiter_id Int
  standort_id    Int
  mitarbeiter    Mitarbeiter @relation(fields: [mitarbeiter_id], references: [id])
  standort       Standort    @relation(fields: [standort_id], references: [id])
}

// ─── Trinkgeldverteilung (BV-103) ──────────────────────────────
// Vom Chef bestätigtes Ergebnis der Trinkgeld-Aufteilung eines Abends (BR #20)
model Trinkgeldverteilung {
  id             Int         @id @default(autoincrement())
  datum          DateTime
  betrag         Float
  bestaetigt_am  DateTime    @default(now())
  mitarbeiter_id Int
  standort_id    Int
  mitarbeiter    Mitarbeiter @relation(fields: [mitarbeiter_id], references: [id])
  standort       Standort    @relation(fields: [standort_id], references: [id])
}

// ─── Erinnerung (BV-101, SMS-Erinnerung simuliert) ─────────────
model Erinnerung {
  id               Int          @id @default(autoincrement())
  versandzeitpunkt DateTime
  status           String       @default("GEPLANT") // GEPLANT | VERSENDET
  reservierung_id  Int          @unique
  reservierung     Reservierung @relation(fields: [reservierung_id], references: [id])
}

// ─── Gruppenmenü (BV-105) ───────────────────────────────────────
model Gruppenmenue {
  id              Int      @id @default(autoincrement())
  bezeichnung     String
  fixpreis        Float
  ab_personenzahl Int      @default(8) // BR #6
  standort_id     Int
  standort        Standort @relation(fields: [standort_id], references: [id])

  reservierungen Reservierung[]
}

// ─── Firmenkunde + Catering-Auftrag (BV-104, W9) ───────────────
model Firmenkunde {
  id              Int    @id @default(autoincrement())
  name            String
  ansprechpartner String
  telefon         String

  cateringAuftraege CateringAuftrag[]
}

model CateringAuftrag {
  id             Int         @id @default(autoincrement())
  event_datum    DateTime
  lieferadresse  String
  status         String      @default("ANGEBOT") // ANGEBOT | BESTAETIGT | ABGESCHLOSSEN | STORNIERT
  erstellt_am    DateTime    @default(now())
  firmenkunde_id Int
  standort_id    Int
  firmenkunde    Firmenkunde @relation(fields: [firmenkunde_id], references: [id])
  standort       Standort    @relation(fields: [standort_id], references: [id])

  positionen   CateringPosition[]
  bestellungen Bestellung[]
}

model CateringPosition {
  id                  Int             @id @default(autoincrement())
  menge               Int
  catering_auftrag_id Int
  gericht_id          Int
  cateringAuftrag     CateringAuftrag @relation(fields: [catering_auftrag_id], references: [id])
  gericht             Gericht         @relation(fields: [gericht_id], references: [id])
}
